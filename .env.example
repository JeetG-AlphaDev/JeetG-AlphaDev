# Application
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://noteshub:password@localhost:5432/noteshub_dev
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# File Storage (S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=noteshub-files
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000/noteshub-files

# AI/LLM Integration
LLM_API_BASE_URL=https://api.your-llm-provider.com/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL=your-preferred-model
STREAMING_SUPPORTED=true

# Payment (Stripe)
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Analytics & Ads
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
PLAUSIBLE_DOMAIN=localhost:3000
ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# File Processing
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=pdf,txt,md,docx

# Admin
ADMIN_EMAIL=admin@noteshub.com
ADMIN_PASSWORD=change-this-password